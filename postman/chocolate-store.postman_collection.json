        },
        {
          "name": "Add item (paste token)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer PASTE_TOKEN_HERE" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"chocolateId\": 1,\n  \"quantity\": 2\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/cart/items",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "cart", "items"]
            }
          }
        },
