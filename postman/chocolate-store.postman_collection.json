          }
        },
        {
          "name": "List types",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/api/types",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "types"]
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser\",\n  \"password\": \"secret123\",\n  \"email\": \"newuser@chocolate.store\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login (returns token)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"demo\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "auth", "login"]
            },
            "description": "Run this first, then copy the 'token' from the response into the Authorization header of the Cart/Orders/Me/Logout requests."
          }
        },
        {
          "name": "Me (paste token)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer PASTE_TOKEN_HERE" }
            ],
            "url": {
              "raw": "http://localhost:3000/api/auth/me",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "auth", "me"]
            }
          }
        },
        {
          "name": "Logout (paste token)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer PASTE_TOKEN_HERE" }
            ],
            "url": {
              "raw": "http://localhost:3000/api/auth/logout",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get cart (paste token)",
          "request": {
            "method": "GET",
            "header": [
